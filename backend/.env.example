# Copy to `.env` in this directory (backend/) when running uvicorn or Alembic from `backend/`.

# SQLite database file (relative paths are resolved from the current working directory).
DATABASE_URL=sqlite:///./data/lego.db

# Logging level for importer and app logs (DEBUG, INFO, WARNING, …).
LOG_LEVEL=INFO

# Set to 1 only for tests or special local setups (skips Alembic head check on startup).
# SKIP_DB_MIGRATION_CHECK=1

# Optional legacy path (Phase 10+ stores images in SQLite BLOBs; not required).
# UPLOAD_ROOT=./data/uploads
# MAX_IMAGE_BYTES=5242880

# Rebrickable API v3 (required for sync in Phase 4B; client tests use mocks only).
REBRICKABLE_API_KEY=your-api-key-here
# REBRICKABLE_BASE_URL=https://rebrickable.com/api/v3/
# REBRICKABLE_TIMEOUT_SECONDS=30
# REBRICKABLE_MAX_RETRIES=3
# Min seconds between API calls (Rebrickable allows ~1 req/s average; 429 if exceeded).
# REBRICKABLE_MIN_REQUEST_INTERVAL_SECONDS=1.0
